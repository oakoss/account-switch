{
  "name": "@oakoss/account-switch",
  "version": "0.2.0",
  "description": "Switch between CLI tool accounts. Supports Claude Code OAuth, with more providers planned.",
  "keywords": [
    "account-switcher",
    "auth",
    "cli",
    "oauth",
    "profile-switch"
  ],
  "homepage": "https://github.com/oakoss/account-switch",
  "bugs": "https://github.com/oakoss/account-switch/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oakoss/account-switch.git"
  },
  "bin": {
    "acsw": "dist/acsw.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "attw": "attw --pack .",
    "build": "bun run clean && bun build src/index.ts --compile --outfile dist/acsw",
    "build:js": "bun run clean && bun build src/index.ts --target node --outfile dist/acsw.js",
    "changeset": "changeset",
    "changeset:auto": "changeset-conventional",
    "changeset:release": "bun run build:js && changeset publish",
    "changeset:version": "changeset version && pnpm format",
    "check-pkg": "bun run build:js && pnpm publint && pnpm attw",
    "clean": "rm -rf dist",
    "clean:cache": "rm -f .*.bun-build",
    "dev": "bun run src/index.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint -c oxlintrc.json src/ tests/",
    "lint:fix": "oxlint -c oxlintrc.json --fix src/ tests/",
    "lint:md": "markdownlint-cli2 'docs/**/*.md' '*.md'",
    "publint": "publint",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.11",
    "changeset-conventional-commits": "^1.0.3",
    "cz-git": "^1.12.0",
    "lefthook": "^2.1.4",
    "markdownlint-cli2": "^0.22.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "publint": "^0.3.18",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
