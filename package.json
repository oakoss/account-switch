{
  "name": "account-switch",
  "version": "1.0.0",
  "description": "Switch between CLI tool accounts. Supports Claude Code OAuth, with more providers planned.",
  "keywords": [
    "account-switcher",
    "auth",
    "cli",
    "oauth",
    "profile-switch"
  ],
  "homepage": "https://github.com/oakoss/account-switch",
  "bugs": "https://github.com/oakoss/account-switch/issues",
  "license": "MIT",
  "repository": "github:oakoss/account-switch",
  "bin": {
    "acsw": "./dist/acsw.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "attw": "attw --pack .",
    "build": "bun build src/index.ts --compile --outfile dist/acsw",
    "build:js": "bun build src/index.ts --target node --outfile dist/acsw.js",
    "check-pkg": "bun run build:js && pnpm publint && pnpm attw",
    "dev": "bun run src/index.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint -c oxlintrc.json src/ tests/",
    "lint:fix": "oxlint -c oxlintrc.json --fix src/ tests/",
    "lint:md": "markdownlint-cli2 'docs/**/*.md' '*.md'",
    "publint": "publint",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.2.0",
    "cz-git": "^1.12.0",
    "lefthook": "^2.1.4",
    "markdownlint-cli2": "^0.22.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "publint": "^0.3.18",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
