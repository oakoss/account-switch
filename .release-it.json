{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "npm": { "publish": false },
  "github": { "release": true },
  "hooks": { "before:init": "bun run build:js" },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": { "name": "conventionalcommits" },
      "infile": "CHANGELOG.md"
    }
  }
}
