{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun"],
    "paths": { "@lib/*": ["./src/lib/*"], "@commands/*": ["./src/commands/*"] }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
